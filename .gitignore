# ═══════════════════════════════════════════════════════════════════════
# MigrationToExtension — .gitignore
# ═══════════════════════════════════════════════════════════════════════

# ── Working directory (generated by pipeline) ──────────────────────────
work/

# ── Extension output (generated by pipeline) ──────────────────────────
extension/

# ── Pipeline reports (generated by scripts) ────────────────────────────
РеестрИзменений.txt
РеестрПроцедур.txt
ОтчётГенерации.txt
ОтчётСборки.txt
ОтчётВерификации.txt
ОтчётДеплоя.txt
ОтчётМетаданных.txt

# ── Input data (user-specific, too large for repo) ─────────────────────
ОтчетОСравнении.txt

# ── Project config (contains local paths) ──────────────────────────────
config.json

# ── Session files (Claude Code / Cursor agent) ─────────────────────────
session-notes.md
tasks.md

# ── Claude Code local settings (contains user-specific permissions) ────
.claude/settings.local.json
.claude/projects/

# ── Environment & secrets ──────────────────────────────────────────────
.env
*.log

# ── Python ─────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
.venv/
venv/
.python-version

# ── OS ─────────────────────────────────────────────────────────────────
Thumbs.db
Desktop.ini
.DS_Store
._*

# ── IDE ────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── Temp ───────────────────────────────────────────────────────────────
*.tmp
temp/
